{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AtelierOS Entity",
  "type": "object",
  "required": ["id", "type", "canonicalName", "aliases", "createdAt", "updatedAt"],
  "properties": {
    "id": { "type": "string" },
    "type": {
      "type": "string",
      "enum": ["project", "process", "client", "person", "company", "municipality", "document", "email", "risk", "action", "agent", "topic"]
    },
    "canonicalName": { "type": "string" },
    "aliases": {
      "type": "array",
      "items": { "type": "string" }
    },
    "source": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "createdAt": { "type": "string" },
    "updatedAt": { "type": "string" }
  }
}
