{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AtelierOS Event",
  "type": "object",
  "required": ["id", "type", "title", "timestamp", "source", "status"],
  "properties": {
    "id": { "type": "string" },
    "type": {
      "type": "string",
      "enum": ["email_received", "document_added", "scan_added", "task_created", "risk_detected", "scope_change_detected", "ticket_received", "roadmap_updated", "agent_executed", "decision_logged"]
    },
    "title": { "type": "string" },
    "summary": { "type": "string" },
    "timestamp": { "type": "string" },
    "source": { "type": "string" },
    "project": { "type": "string" },
    "relatedEntities": {
      "type": "array",
      "items": { "type": "string" }
    },
    "priority": {
      "type": "string",
      "enum": ["baixa", "media", "alta", "critica"]
    },
    "status": {
      "type": "string",
      "enum": ["detected", "suggested", "accepted", "rejected", "done"]
    }
  }
}
